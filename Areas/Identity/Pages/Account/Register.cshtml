@page
@model RegisterModel
@{
    ViewData["Title"] = "Регистрација";
}

<div class="container py-5 fade-in">
    <div class="row justify-content-center">
        <div class="col-12 col-md-10 col-lg-7">
            
           
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                
                <div class="card-header bg-white border-0 text-center pt-5 pb-3">
                    <div class="d-inline-flex align-items-center justify-content-center bg-light rounded-circle mb-3 shadow-sm" style="width: 70px; height: 70px;">
                        <i class="bi bi-person-plus-fill fs-1 text-primary"></i>
                    </div>
                    <h3 class="fw-bold text-dark mb-1">Креирајте нов профил</h3>
                    <p class="text-muted small">Пополнете ги вашите податоци за да станете дел од нашата продавница.</p>
                </div>

                <div class="card-body px-4 px-md-5 pb-5 pt-2">
                    
                    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 small fw-bold" role="alert"></div>

                        <h6 class="fw-bold text-primary mb-3"><i class="bi bi-shield-lock me-2"></i>Податоци за системска најава</h6>
                        
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control bg-light border-0 shadow-none" 
                                   style="border-radius: 10px;" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email" class="text-muted"><i class="bi bi-envelope me-2"></i>Е-маил адреса</label>
                            <span asp-validation-for="Input.Email" class="text-danger small fw-bold mt-1 d-block"></span>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Input.Password" class="form-control bg-light border-0 shadow-none" 
                                           style="border-radius: 10px;" autocomplete="new-password" aria-required="true" placeholder="password" />
                                    <label asp-for="Input.Password" class="text-muted"><i class="bi bi-lock me-2"></i>Лозинка</label>
                                    <span asp-validation-for="Input.Password" class="text-danger small fw-bold mt-1 d-block"></span>
                                </div>
                            </div>
                            <div class="col-md-6 mb-4">
                                <div class="form-floating">
                                    <input asp-for="Input.ConfirmPassword" class="form-control bg-light border-0 shadow-none" 
                                           style="border-radius: 10px;" autocomplete="new-password" aria-required="true" placeholder="password" />
                                    <label asp-for="Input.ConfirmPassword" class="text-muted"><i class="bi bi-lock-fill me-2"></i>Потврди лозинка</label>
                                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small fw-bold mt-1 d-block"></span>
                                </div>
                            </div>
                        </div>

                        <hr class="text-muted opacity-25 my-4">

                        <h6 class="fw-bold text-primary mb-3"><i class="bi bi-box-seam me-2"></i>Профил и податоци за достава</h6>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Input.FirstName" class="form-control bg-light border-0 shadow-none" style="border-radius: 10px;" placeholder="First Name" />
                                    <label asp-for="Input.FirstName" class="text-muted"><i class="bi bi-person me-2"></i>Име</label>
                                    <span asp-validation-for="Input.FirstName" class="text-danger small fw-bold mt-1 d-block"></span>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Input.LastName" class="form-control bg-light border-0 shadow-none" style="border-radius: 10px;" placeholder="Last Name" />
                                    <label asp-for="Input.LastName" class="text-muted"><i class="bi bi-people me-2"></i>Презиме</label>
                                    <span asp-validation-for="Input.LastName" class="text-danger small fw-bold mt-1 d-block"></span>
                                </div>
                            </div>
                        </div>

                        
                        <div class="form-floating mb-3">
                            <input asp-for="Input.StreetAdress" class="form-control bg-light border-0 shadow-none" style="border-radius: 10px;" placeholder="Street Address" />
                            <label asp-for="Input.StreetAdress" class="text-muted"><i class="bi bi-geo-alt me-2"></i>Улица и број (Адреса)</label>
                            <span asp-validation-for="Input.StreetAdress" class="text-danger small fw-bold mt-1 d-block"></span>
                        </div>

                       
                        <div class="row mb-4">
                            <div class="col-md-6 mb-3 mb-md-0">
                                <div class="form-floating">
                                    <input asp-for="Input.City" class="form-control bg-light border-0 shadow-none" style="border-radius: 10px;" placeholder="City" />
                                    <label asp-for="Input.City" class="text-muted"><i class="bi bi-buildings me-2"></i>Град</label>
                                    <span asp-validation-for="Input.City" class="text-danger small fw-bold mt-1 d-block"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Input.PostalCode" class="form-control bg-light border-0 shadow-none" style="border-radius: 10px;" placeholder="Postal Code" />
                                    <label asp-for="Input.PostalCode" class="text-muted"><i class="bi bi-mailbox me-2"></i>Поштенски код</label>
                                    <span asp-validation-for="Input.PostalCode" class="text-danger small fw-bold mt-1 d-block"></span>
                                </div>
                            </div>
                        </div>

                        
                        <div class="mt-4">
                            <button id="registerSubmit" type="submit" class="btn btn-primary btn-lg w-100 fw-bold shadow-sm" style="border-radius: 10px; letter-spacing: 0.5px;">
                                Регистрирај се <i class="bi bi-arrow-right-circle ms-2"></i>
                            </button>
                        </div>
                    </form>

                   
                    @{
                        if ((Model.ExternalLogins?.Count ?? 0) > 0)
                        {
                            <div class="d-flex align-items-center my-4">
                                <hr class="flex-grow-1 text-muted">
                                <span class="mx-3 text-muted small fw-bold text-uppercase">Или регистрирајте се со</span>
                                <hr class="flex-grow-1 text-muted">
                            </div>

                            <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                                <div class="d-grid gap-2">
                                    @foreach (var provider in Model.ExternalLogins!)
                                    {
                                        <button type="submit" class="btn btn-outline-secondary fw-bold rounded-pill" name="provider" value="@provider.Name">
                                            @provider.DisplayName
                                        </button>
                                    }
                                </div>
                            </form>
                        }
                    }

                </div>
                
                
                <div class="card-footer bg-light border-0 text-center py-4">
                    <p class="mb-0 text-secondary small fw-semibold">
                        Веќе имате профил? 
                        <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="text-primary fw-bold text-decoration-none">
                            Најавете се тука
                        </a>
                    </p>
                </div>
                
            </div>
            
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
