@model e_store.Areas.Admin.Models.ViewModels.UserDetailViewModel

@{
    ViewData["Title"] = "Детали за Корисник";
}

<div class="container-fluid px-0 py-4 fade-in">
    <!-- Хедер со копче за назад -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-0">
                <i class="bi bi-person-lines-fill text-primary me-2"></i> Профил на Корисник
            </h3>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 fw-bold">
            <i class="bi bi-arrow-left me-2"></i> Назад кон листата
        </a>
    </div>

    <div class="row g-4">
        <!-- ЛЕВА КОЛОНА: Информации за корисникот -->
        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4 text-center">
                    <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center text-primary fw-bold mx-auto mb-3" style="width: 80px; height: 80px; font-size: 2rem;">
                        @Model.FirstName?.FirstOrDefault()@Model.LastName?.FirstOrDefault()
                    </div>
                    <h4 class="fw-bold text-dark mb-1">@Model.FirstName @Model.LastName</h4>
                    <p class="text-muted mb-3"><a href="mailto:@Model.Email" class="text-decoration-none text-muted">@Model.Email</a></p>
                    
                    <div class="mb-4">
                        @if (Model.Roles != null && Model.Roles.Contains("Admin"))
                        {
                            <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-4 py-2 fw-bold">
                                <i class="bi bi-shield-lock-fill me-1"></i> Админ
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill px-4 py-2 fw-bold">
                                <i class="bi bi-person-fill me-1"></i> Обичен Корисник
                            </span>
                        }
                    </div>

                    <hr class="text-muted opacity-25">

                    <div class="d-flex justify-content-between text-start mt-3">
                        <span class="text-muted small fw-bold">Вкупно Нарачки:</span>
                        <span class="fw-bold text-dark">@Model.Orders.Count()</span>
                    </div>
                    <div class="d-flex justify-content-between text-start mt-2">
                        <span class="text-muted small fw-bold">ID на корисник:</span>
                        <span class="text-muted font-monospace small">@Model.UserId.Substring(0, 8)...</span>
                    </div>
                    
                    <div class="mt-4">
                        <a asp-action="ManageRole" asp-route-id="@Model.UserId" class="btn btn-light w-100 fw-bold rounded-3">
                            <i class="bi bi-person-gear me-2"></i> Промени Улога
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- ДЕСНА КОЛОНА: Историја на Нарачки -->
        <div class="col-12 col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <h5 class="fw-bold text-dark mb-0">
                        <i class="bi bi-bag-check me-2 text-success"></i> Историја на нарачки
                    </h5>
                </div>
                <div class="card-body p-0 mt-3">
                    @if (Model.Orders != null && Model.Orders.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="text-uppercase text-secondary small fw-bold px-4 py-3">Нарачка #</th>
                                        <th class="text-uppercase text-secondary small fw-bold py-3">Датум</th>
                                        <th class="text-uppercase text-secondary small fw-bold text-end py-3">Вкупно</th>
                                        <th class="text-uppercase text-secondary small fw-bold text-center px-4 py-3">Статус</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in Model.Orders)
                                    {
                                        <tr style="cursor: pointer;" onclick="window.location.href='@Url.Action("Details", "Order", new { id = order.Id })';">
                                            <td class="px-4 py-3 font-monospace fw-bold text-primary">#@order.Id</td>
                                            <td class="py-3">@order.OrderDate.ToString("dd.MM.yyyy HH:mm")</td>
                                            <td class="text-end fw-bold py-3">@order.TotalAmount.ToString("N2") ден.</td>
                                            <td class="text-center px-4 py-3">
                                                @* Прилагоди ги боите зависно од тоа кои статуси ги имаш *@
                                                <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3">@order.OrderStatus</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-cart-x text-muted opacity-50 display-1 mb-3"></i>
                            <h5 class="text-muted fw-bold">Овој корисник нема направено нарачки.</h5>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>