@model e_store.Areas.Admin.Models.ViewModels.UserRoleViewModel
@{
    ViewData["Title"] = "Промени Улога";
}

<div class="container-fluid px-0 py-4 fade-in">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h3 class="fw-bold text-dark mb-0">
                        <i class="bi bi-person-gear text-warning me-2"></i> Промени Улога
                    </h3>
                    <p class="text-muted small mt-1 mb-0">Управување со привилегиите на корисникот.</p>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 p-md-5">
                    
                    <div class="d-flex align-items-center mb-4 p-3 bg-light rounded-3">
                        <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center text-primary fw-bold me-3" style="width: 50px; height: 50px; font-size: 1.2rem;">
                            @Model.Email.Substring(0, 1).ToUpper()
                        </div>
                        <div>
                            <p class="text-muted small mb-0">Корисник</p>
                            <h6 class="mb-0 fw-bold text-dark">@Model.Email</h6>
                        </div>
                    </div>

                    <form asp-action="ManageRole" method="post">
                        <input type="hidden" name="userId" value="@Model.UserId" />

                        <div class="mb-4">
                            <label class="form-label fw-bold text-secondary">Избери нова улога</label>
                            <select name="selectedRole" class="form-select form-select-lg" style="border-radius: 10px;">
                                @foreach (var role in Model.AllRoles)
                                {
                                    if (role.Equals(Model.Role))
                                    {
                                        <option value="@role" selected>@role (Моментална)</option>
                                    }
                                    else
                                    {
                                        <option value="@role">@role</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="d-flex gap-2 pt-2">
                            <a asp-action="Index" class="btn btn-light btn-lg w-50 fw-bold rounded-3">
                                <i class="bi bi-arrow-left me-2"></i> Откажи
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg w-50 fw-bold rounded-3 shadow-sm">
                                <i class="bi bi-check2-circle me-2"></i> Зачувај 
                            </button>
                        </div>
                    </form>

                </div>
            </div>
            
        </div>
    </div>
</div>