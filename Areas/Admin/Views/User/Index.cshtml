@model IEnumerable<e_store.Areas.Admin.Models.ViewModels.UserRoleViewModel>

@{
    ViewData["Title"] = "Корисници";
}

<div class="container-fluid px-0 py-4 fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4 px-2">
        <div>
            <h2 class="fw-bold text-dark mb-0">
                <i class="bi bi-people-fill text-primary me-2"></i> Управување со Корисници
            </h2>
            <p class="text-muted small mt-1 mb-0">Преглед и менаџирање на сите регистрирани корисници и нивните улоги.</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="text-uppercase text-secondary small fw-bold px-4 py-3" style="letter-spacing: 0.5px;">Корисник</th>
                            <th class="text-uppercase text-secondary small fw-bold py-3" style="letter-spacing: 0.5px;">Емаил Адреса</th>
                            <th class="text-uppercase text-secondary small fw-bold text-center py-3" style="letter-spacing: 0.5px;">Улога</th>
                            <th class="text-uppercase text-secondary small fw-bold text-end px-4 py-3" style="letter-spacing: 0.5px;">Акции</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr class="clickable-row" style="cursor: pointer;" onclick="window.location.href='@Url.Action("Details", "User", new { id = user.UserId })';">
                                <td class="px-4 py-3">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center text-primary fw-bold me-3" style="width: 45px; height: 45px; font-size: 1.1rem;">
                                            @user.FirstName?.FirstOrDefault()@user.LastName?.FirstOrDefault()
                                        </div>
                                        <div>
                                            <h6 class="mb-0 text-dark fw-bold">@user.FirstName @user.LastName</h6>
                                            <span class="text-muted font-monospace" style="font-size: 0.75rem;">ID: @user.UserId.Substring(0, 8)...</span>
                                        </div>
                                    </div>
                                </td>
                                
                                <td class="py-3">
                                    <a href="mailto:@user.Email" class="text-decoration-none text-muted" onclick="event.stopPropagation();">@user.Email</a>
                                </td>
                                
                                <td class="text-center py-3">
                                    @if (user.Role != null && user.Role.Contains("Admin"))
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-3 py-2 fw-bold">
                                            <i class="bi bi-shield-lock-fill me-1"></i> Админ
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill px-3 py-2 fw-bold">
                                            <i class="bi bi-person-fill me-1"></i> Корисник
                                        </span>
                                    }
                                </td>
                                
                                <td class="text-end px-4 py-3">
                                    <div class="dropdown" onclick="event.stopPropagation();">
                                        <button class="btn btn-light btn-sm rounded-circle p-2" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            <i class="bi bi-three-dots-vertical"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow border-0" style="border-radius: 12px;">
                                            <li>
                                                <a class="dropdown-item fw-bold text-primary py-2" asp-action="Details" asp-route-id="@user.UserId">
                                                    <i class="bi bi-eye me-2"></i> Прегледај Нарачки
                                                </a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item fw-bold text-warning py-2" asp-action="ManageRole" asp-route-id="@user.UserId">
                                                    <i class="bi bi-person-gear me-2"></i> Промени Улога
                                                </a>
                                            </li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-people text-muted opacity-50 display-1 mb-3"></i>
                    <h5 class="text-muted fw-bold">Нема пронајдено корисници.</h5>
                </div>
            }
        </div>
        <div class="card-footer bg-white border-top-0 py-3 px-4 rounded-bottom-4">
            <p class="text-muted small mb-0">Вкупно корисници: <span class="fw-bold text-dark">@Model.Count()</span></p>
        </div>
    </div>
</div>

