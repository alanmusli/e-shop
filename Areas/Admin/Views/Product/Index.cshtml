
@model IEnumerable<e_store.Models.Product>
@{
    var currentSlug = ViewContext.RouteData.Values["slug"]?.ToString() ?? "all";
    var currentBrand = ViewContext.RouteData.Values["brandName"]?.ToString().ToLower();
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}


<div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2><i class="bi bi-box-seam me-2"></i>Product Inventory Dashboard</h2>
            <a asp-area="Admin" asp-action="Create" asp-controller="Product" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i> Add New Product
            </a>
        </div>

        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                    <tr>
                        <th>Product Name</th>
                        <th>Brand</th>
                        <th>Category Absolute Path</th>
                        <th class="text-end">Price</th>
                        <th class="text-center">Stock Level</th>
                        <th class="text-end">Management Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <strong>@item.Name</strong>
                                <br/>
                                <small class="text-muted text-monospace">@item.Category.Slug</small>
                            </td>
                            <td>@item.Brand?.Name</td>
                            <td>
                                <span class="badge bg-light text-dark border">
                                    @item.Category?.Slug
                                </span>
                            </td>
                            <td class="text-end fw-bold">@item.Price.ToString("F2") den</td>
                            <td class="text-center">
                                @if (item.InventoryCount == 0)
                                {
                                    <span class="badge bg-danger">Nema zaliha</span>
                                }
                                else if (item.InventoryCount < 10)
                                {
                                    <span class="badge bg-warning text-dark">Niska zaliha (@item.InventoryCount)</span>
                                }
                                else
                                {
                                        <span class="badge bg-success">@item.InventoryCount Dostapni</span>
                                        
                                }
                            </td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm" role="group">
                                        <a asp-area="Admin" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary" title="Edit Properties">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-area="Admin" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger" title="Remove Product">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    <a asp-area="Admin" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info" title="View Audit Details">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

