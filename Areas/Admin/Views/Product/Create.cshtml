@model e_store.Models.Product

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Нов Продукт";
}

<div class="container-fluid py-4" style="max-width: 900px;">
    <!-- Навигациска Лента -->
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
            <a asp-action="Index" class="btn btn-sm btn-light font-monospace text-uppercase fw-bold text-muted small px-3">
                <i class="bi bi-arrow-left me-2"></i>Откажи и назад
            </a>
        </div>
        <div>
            <span class="badge bg-primary font-monospace px-3 py-2">
                КРЕИРАЊЕ НОВ ПРОДУКТ
            </span>
        </div>
    </div>

    <!-- Главна Форма Картичка -->
    <div class="card border-0 shadow-sm" style="border-radius: 12px;">
        <div class="card-header bg-light border-0 py-3">
            <h5 class="mb-0 fw-bold bistrejd-text-blue">
                <i class="bi bi-plus-square-dotted me-2"></i>Форма за внес на податоци
            </h5>
        </div>
        <div class="card-body p-4 p-md-5">
            <form asp-area="Admin" asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 small fw-bold mb-4"></div>

                <div class="mb-4">
                    <label asp-for="Name" class="form-label font-monospace small fw-bold text-muted text-uppercase">Име на производ</label>
                    <input asp-for="Name" class="form-control border shadow-none py-2" style="border-radius: 8px;" placeholder="Пр: DeWalt 20V Max XR..." />
                    <span asp-validation-for="Name" class="text-danger small fw-bold mt-1 d-block"></span>
                </div>

                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <label asp-for="BrandId" class="form-label font-monospace small fw-bold text-muted text-uppercase">Производител / Бренд</label>
                        <select asp-for="BrandId" class="form-select border shadow-none py-2" style="border-radius: 8px;" asp-items="ViewBag.BrandId">
                            <option value="">-- Избери бренд --</option>
                        </select>
                        <span asp-validation-for="BrandId" class="text-danger small fw-bold mt-1 d-block"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="CategoryId" class="form-label font-monospace small fw-bold text-muted text-uppercase">Доделена Категорија</label>
                        <select asp-for="CategoryId" class="form-select border shadow-none py-2" style="border-radius: 8px;" asp-items="ViewBag.CategoryId">
                            <option value="">-- Избери категорија --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small fw-bold mt-1 d-block"></span>
                    </div>
                </div>

                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <label asp-for="Price" class="form-label font-monospace small fw-bold text-muted text-uppercase">Продажна цена (ден.)</label>
                        <div class="input-group">
                            <input asp-for="Price" class="form-control border shadow-none py-2" style="border-top-left-radius: 8px; border-bottom-left-radius: 8px;" type="number" step="1" min="1" placeholder="0" />
                            <span class="input-group-text bg-light fw-bold font-monospace text-muted">ден.</span>
                        </div>
                        <span asp-validation-for="Price" class="text-danger small fw-bold mt-1 d-block"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="InventoryCount" class="form-label font-monospace small fw-bold text-muted text-uppercase">Почетна состојба на залиха</label>
                        <input asp-for="InventoryCount" class="form-control border shadow-none py-2" style="border-radius: 8px;" type="number" step="1" min="0" placeholder="0" />
                        <span asp-validation-for="InventoryCount" class="text-danger small fw-bold mt-1 d-block"></span>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label font-monospace small fw-bold text-muted text-uppercase">Технички спецификации & Опис</label>
                    <textarea asp-for="Description" class="form-control border shadow-none p-3 font-monospace small" style="border-radius: 8px;" rows="4" placeholder="Внесете детален опис, перформанси, димензии или материјали..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small fw-bold mt-1 d-block"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center border-top pt-4 mt-5">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2 fw-medium" style="border-radius: 8px;">
                        <i class="bi bi-x-circle me-2"></i>Откажи
                    </a>
                    <button type="submit" class="btn btn-primary px-5 py-2 fw-bold text-uppercase shadow-sm" style="border-radius: 8px;">
                        <i class="bi bi-check-circle-fill me-2"></i>Креирај Производ
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}