@model e_store.Models.Product

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Преглед на Продукт";
}

<div class="container-fluid py-4 max-width: 1100px;">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
            <a asp-action="Index" class="btn btn-sm btn-light font-monospace text-uppercase fw-bold text-muted small px-3">
                <i class="bi bi-arrow-left me-2"></i>Назад кон лагер
            </a>
        </div>
        <div class="d-flex align-items-center gap-2">
            <span class="badge bg-secondary font-monospace px-3 py-2">
                PRODUCT ID: #@Model.Id
            </span>
            @if (Model.InventoryCount == 0)
            {
                <span class="badge bg-danger px-3 py-2 text-uppercase font-monospace">Распродадено</span>
            }
            else
            {
                <span class="badge bg-success px-3 py-2 text-uppercase font-monospace">Активен Лагер</span>
            }
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm mb-4" style="border-radius: 12px;">
                <div class="card-header bg-light border-0 py-3">
                    <h5 class="mb-0 fw-bold bistrejd-text-blue"><i class="bi bi-info-circle me-2"></i>Спецификации на системски запис</h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-bordered align-middle mb-0 text-dark">
                        <tbody>
                            <tr>
                                <th class="bg-light fw-bold font-monospace text-muted small px-4" style="width: 25%;">Име на Продукт</th>
                                <td class="px-4 fw-bold fs-5 bistrejd-text-blue">@Model.Name</td>
                            </tr>
                            <tr>
                                <th class="bg-light fw-bold font-monospace text-muted small px-4">Системско SKU</th>
                                <td class="px-4"><span class="badge border font-monospace text-dark px-3 py-1 bg-light">@Model.SKU</span></td>
                            </tr>
                            <tr>
                                <th class="bg-light fw-bold font-monospace text-muted small px-4">Производител (Бренд)</th>
                                <td class="px-4 fw-semibold">@(Model.Brand?.Name ?? "Нема бренд")</td>
                            </tr>
                            <tr>
                                <th class="bg-light fw-bold font-monospace text-muted small px-4">Категорија</th>
                                <td class="px-4 text-primary fw-medium">
                                    <i class="bi bi-folder me-1"></i> @(Model.Category?.Name ?? "Нема категорија")
                                    <span class="text-muted small font-monospace d-block">URL Slug: /catalog/@Model.Category?.Slug</span>
                                </td>
                            </tr>
                            <tr>
                                <th class="bg-light fw-bold font-monospace text-muted small px-4">Продажна Цена</th>
                                <td class="px-4 fw-bold text-danger fs-5">@Model.Price.ToString("N0") ден.</td>
                            </tr>
                            <tr>
                                <th class="bg-light fw-bold font-monospace text-muted small px-4">Состојба на залиха</th>
                                <td class="px-4">
                                    @if (Model.InventoryCount == 0)
                                    {
                                        <span class="text-danger fw-bold"><i class="bi bi-exclamation-triangle-fill me-1"></i> 0 парчиња (Потребна е набавка)</span>
                                    }
                                    else
                                    {
                                        <span class="text-success fw-bold font-monospace fs-5">@Model.InventoryCount</span> <span class="text-muted small">парчиња на лагер</span>
                                    }
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card border-0 shadow-sm" style="border-radius: 12px;">
                <div class="card-header bg-light border-0 py-3">
                    <h6 class="mb-0 fw-bold text-uppercase font-monospace text-muted small"><i class="bi bi-file-text me-2"></i>Технички Опис / Спецификации</h6>
                </div>
                <div class="card-body p-4">
                    <p class="text-dark bg-light p-3 rounded-3 font-monospace small mb-0" style="white-space: pre-line; line-height: 1.6; border: 1px solid #dee2e6;">
                        @(string.IsNullOrWhiteSpace(Model.Description) ? "Нема внесен опис или технички спецификации за овој производ." : Model.Description)
                    </p>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm p-4 text-center mb-4" style="border-radius: 12px;">
                <h6 class="text-start fw-bold text-uppercase font-monospace text-muted small mb-3"><i class="bi bi-image me-2"></i>Продукт Слика</h6>
                <div class="bg-light border rounded-3 p-3 d-flex align-items-center justify-content-center" style="height: 220px; overflow: hidden;">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" class="img-fluid" style="max-height: 100%; object-fit: contain;" alt="Слика на продукт" />
                    }
                    else
                    {
                        <div class="text-muted">
                            <i class="bi bi-image-alt fs-1 d-block mb-1 opacity-50"></i>
                            <span class="small font-monospace">Нема слика</span>
                        </div>
                    }
                </div>
            </div>

            <div class="card border-0 shadow-sm p-4 h-auto" style="border-radius: 12px; background-color: var(--brand-blue); color: white;">
                <h6 class="fw-bold text-uppercase font-monospace mb-4 small text-white bg-white bg-opacity-10 p-2 rounded text-center"><i class="bi bi-shield-check me-2"></i>Администраторски акции</h6>
                
                <div class="d-grid gap-2">
                    <a asp-area="Admin" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning fw-bold py-3 text-uppercase rounded-3 shadow-sm" style="font-size: 13px;">
                        <i class="bi bi-pencil-square me-2"></i> Измени податоци (Edit)
                    </a>
                    
                    <a asp-area="Admin" asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger border-0 bg-white bg-opacity-10 text-white fw-bold py-2 rounded-3 mt-2" style="font-size: 12px;">
                        <i class="bi bi-trash me-1"></i> Избриши од база
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>