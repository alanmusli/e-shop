@model e_store.Models.Order

@{
    ViewData["Title"] = $"Детали за Нарачка #ORD-{Model.Id}";
    
    // Логика за бојата на баџот според статусот
    var status = (Model.OrderStatus ?? "нова").ToLower();
    var badgeClass = "bg-secondary text-secondary border-secondary";
    var icon = "bi-circle";

    if(status == "нова" || status == "new") { badgeClass = "bg-info text-info border-info"; icon = "bi-asterisk"; }
    else if(status == "во обработка" || status == "processing") { badgeClass = "bg-warning text-warning border-warning"; icon = "bi-box-seam"; }
    else if(status == "пратена" || status == "shipped") { badgeClass = "bg-primary text-primary border-primary"; icon = "bi-truck"; }
    else if(status == "доставена" || status == "delivered") { badgeClass = "bg-success text-success border-success"; icon = "bi-check-circle"; }
    else if(status == "откажана" || status == "canceled") { badgeClass = "bg-danger text-danger border-danger"; icon = "bi-x-circle"; }
}

<div class="container-fluid fade-in mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom" style="border-color: rgba(28, 28, 132, 0.1) !important;">
        <div>
            <a asp-action="Index" class="btn btn-sm btn-light border mb-2 text-muted fw-bold shadow-sm" style="font-size: 12px;">
                <i class="bi bi-arrow-left me-1"></i> Назад кон сите нарачки
            </a>
            <h2 class="fw-bold bistrejd-text-blue mb-0 d-flex align-items-center gap-3">
                <span>Нарачка <span class="font-monospace" style="color: var(--brand-red);">#ORD-@Model.Id</span></span>
                <span class="badge @badgeClass bg-opacity-10 border rounded-pill px-3 py-2 fw-bold" style="font-size: 13px; letter-spacing: 0.5px;">
                    <i class="bi @icon me-1"></i> @(Model.OrderStatus?.ToUpper() ?? "НОВА")
                </span>
            </h2>
        </div>
        <div class="d-flex gap-2">
            <button onclick="window.print()" class="btn btn-outline-secondary fw-bold rounded-3 shadow-sm d-none d-md-block">
                <i class="bi bi-printer me-2"></i> Испечати Испратница
            </button>
            
            <div class="dropdown">
                <button class="btn bistrejd-btn-red fw-bold rounded-3 shadow-sm dropdown-toggle text-uppercase" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="letter-spacing: 0.5px;">
                    <i class="bi bi-arrow-repeat me-1"></i> Смени Статус
                </button>
                <form asp-action="ChangeStatus" asp-controller="Order" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
    
                    <ul class="dropdown-menu dropdown-menu-end shadow border-0" style="border-radius: 12px;">
                        <li>
                            <button type="submit" name="status" value="new" class="dropdown-item fw-bold text-info py-2">
                                <i class="bi bi-asterisk me-2"></i> Означи како Нова
                            </button>
                        </li>
                        <li>
                            <button type="submit" name="status" value="processing" class="dropdown-item fw-bold text-warning py-2">
                                <i class="bi bi-box-seam me-2"></i> Во Обработка (Се пакува)
                            </button>
                        </li>
                        <li>
                            <button type="submit" name="status" value="shipped" class="dropdown-item fw-bold text-primary py-2">
                                <i class="bi bi-truck me-2"></i> Означи како Пратена
                            </button>
                        </li>
                        <li>
                            <button type="submit" name="status" value="delivered" class="dropdown-item fw-bold text-success py-2">
                                <i class="bi bi-check-circle me-2"></i> Означи како Доставена
                            </button>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <button type="submit" name="status" value="cancelled" class="dropdown-item fw-bold text-danger py-2">
                                <i class="bi bi-x-circle me-2"></i> Откажи Нарачка
                            </button>
                        </li>
                    </ul>
                </form>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                    <h6 class="fw-bold bistrejd-text-blue text-uppercase mb-0" style="letter-spacing: 1px;"><i class="bi bi-person-badge me-2"></i> Податоци за Купувач</h6>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-3">
                            <span class="d-block text-muted small font-monospace mb-1">Име и Презиме</span>
                            <span class="fw-bold text-dark fs-6">@Model.ShippingFirstName @Model.ShippingLastName</span>
                        </li>
                        <li class="mb-3">
                            <span class="d-block text-muted small font-monospace mb-1">Телефонски Број</span>
                            <span class="fw-bold text-dark"><i class="bi bi-telephone-fill me-2 text-muted small"></i>@Model.ShippingPhoneNumber</span>
                        </li>
                        <li>
                            <span class="d-block text-muted small font-monospace mb-1">Датум на Нарачка</span>
                            <span class="fw-bold text-dark">
                                <i class="bi bi-calendar3 me-2 text-muted small"></i>@Model.OrderDate.ToString("dd MMMM yyyy") 
                                <span class="text-muted fw-normal ms-1">во @Model.OrderDate.ToString("HH:mm") ч.</span>
                            </span>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4" style="background-color: var(--brand-light);">
                <div class="card-header border-bottom-0 pt-4 pb-0 bg-transparent">
                    <h6 class="fw-bold bistrejd-text-blue text-uppercase mb-0" style="letter-spacing: 1px;"><i class="bi bi-geo-alt me-2"></i> Адреса за Испорака</h6>
                </div>
                <div class="card-body">
                    <p class="mb-1 fw-bold text-dark">@(Model.ShippingAddress ?? "Не е внесена адреса")</p>
                    <p class="mb-0 text-muted">@(Model.ShippingCity ?? "Не е внесен град")</p>
                    @* <div class="mt-4 p-3 bg-white rounded-3 border"> *@
                    @*     <span class="d-block text-muted small font-monospace mb-1"><i class="bi bi-chat-left-text me-1"></i> Забелешка од купувачот:</span> *@
                    @*     <p class="mb-0 small fst-italic text-dark">@(string.IsNullOrWhiteSpace(Model.) ? "Нема дополнителни забелешки." : Model.ShippingNotes)</p> *@
                    @* </div> *@
                </div>
            </div>

        </div>

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 h-100 d-flex flex-column">
                <div class="card-header bg-white border-bottom p-4">
                    <h6 class="fw-bold bistrejd-text-blue text-uppercase mb-0" style="letter-spacing: 1px;"><i class="bi bi-box me-2"></i> Нарачани Продукти</h6>
                </div>
                
                <div class="card-body p-0 flex-grow-1">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0 table-hover">
                            <thead class="bg-light text-muted small text-uppercase font-monospace">
                                <tr>
                                    <th class="ps-4 py-3 border-0">Продукт</th>
                                    <th class="py-3 text-center border-0">Количина</th>
                                    <th class="py-3 text-end border-0">Единечна Цена</th>
                                    <th class="pe-4 py-3 text-end border-0">Вкупно</th>
                                </tr>
                            </thead>
                            <tbody style="border-top: 2px solid rgba(28, 28, 132, 0.05);">
                                @if (Model.OrderDetails != null && Model.OrderDetails.Any())
                                {
                                    foreach (var detail in Model.OrderDetails)
                                    {
                                        var lineTotal = detail.Quantity * detail.Price;
                                        <tr>
                                            <td class="ps-4 py-3">
                                                <div class="d-flex align-items-center">
                                                    <div class="rounded bg-light border p-2 me-3 text-center shadow-sm" style="width: 45px; height: 45px;">
                                                        <i class="bi bi-tag text-muted fs-5"></i>
                                                    </div>
                                                    <div>
                                                        <h6 class="mb-0 fw-bold bistrejd-text-blue text-truncate" style="max-width: 250px;">@(detail.Product?.Name ?? "Непознат Продукт")</h6>
                                                        <span class="text-muted small font-monospace">SKU: @(detail.Product?.SKU ?? "/")</span>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-center fw-bold font-monospace fs-5">
                                                x @detail.Quantity
                                            </td>
                                            <td class="text-end text-muted font-monospace">
                                                @detail.Price.ToString("N0") ден.
                                            </td>
                                            <td class="pe-4 text-end fw-bold text-dark font-monospace fs-6">
                                                @lineTotal.ToString("N0") ден.
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-5 text-muted">
                                            <i class="bi bi-bag-x fs-1 d-block mb-3 opacity-50"></i>
                                            Оваа нарачка нема регистрирано продукти во базата.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="card-footer bg-white border-top p-4">
                    <div class="row justify-content-end">
                        <div class="col-md-6 col-lg-5">
                            <div class="d-flex justify-content-between mb-2 text-muted small">
                                <span>Меѓузбир:</span>
                                <span class="font-monospace fw-bold">@Model.TotalAmount.ToString("N0") ден.</span>
                            </div>
                            <div class="d-flex justify-content-between mb-3 text-muted small pb-3 border-bottom">
                                <span>Испорака:</span>
                                <span class="font-monospace fw-bold">0 ден.</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold bistrejd-text-blue text-uppercase" style="letter-spacing: 1px;">Вкупно за Наплата:</span>
                                <span class="fs-3 fw-bold font-monospace" style="color: var(--brand-red);">@Model.TotalAmount.ToString("N0") ден.</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fade-in { animation: fadeIn 0.4s ease-in; }
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    @@media print {
        .navbar, .btn, .dropdown, header, footer { display: none !important; }
        .card { border: 1px solid #dee2e6 !important; box-shadow: none !important; }
        body { background-color: white !important; }
    }
</style>