
@model e_store.Models.Category

@{
    ViewData["Title"] = "Измена на категорија";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4" style="max-width: 800px;">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
            <a asp-action="Index" class="btn btn-sm btn-light font-monospace text-uppercase fw-bold text-muted small px-3">
                <i class="bi bi-arrow-left me-2"></i>Откажи и назад
            </a>
        </div>
        <div>
            <span class="badge bg-secondary font-monospace px-3 py-2">
                ИЗМЕНА НА ЈАЗОЛ #@Model.Id
            </span>
        </div>
    </div>


    <div class="card border-0 shadow-sm" style="border-radius: 12px;">
        <div class="card-header bg-light border-0 py-3">
            <h5 class="mb-0 fw-bold bistrejd-text-blue">
                <i class="bi bi-pencil-square me-2"></i>Параметри за конфигурација на гранка
            </h5>
        </div>
        
        <div class="card-body p-4 p-md-5">
            <form asp-action="Edit" method="post" asp-area="Admin">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 small fw-bold mb-4"></div>
                
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="Slug" />

                <div class="mb-4">
                    <label asp-for="Name" class="form-label font-monospace small fw-bold text-muted text-uppercase">Наслов на категоријата</label>
                    <input asp-for="Name" class="form-control border shadow-none py-2" style="border-radius: 8px;" placeholder="Внесете име..." />
                    <span asp-validation-for="Name" class="text-danger small fw-bold mt-1 d-block"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ParentCategoryId" class="form-label font-monospace small fw-bold text-muted text-uppercase">Цел за релациско поместување</label>
                    <select asp-for="ParentCategoryId" class="form-select border shadow-none py-2" style="border-radius: 8px;" asp-items="ViewBag.ParentCategoryId">
                        <option value="">-- Главен јазол (Root) --</option>
                    </select>
                    <span asp-validation-for="ParentCategoryId" class="text-danger small fw-bold mt-1 d-block"></span>
                    
                    <div class="mt-3 p-3 bg-warning bg-opacity-10 border border-warning border-opacity-25 rounded-3">
                        <p class="mb-0 text-warning-emphasis small fw-bold">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>Внимание: Преместувањето на овој јазол ќе предизвика каскадно ажурирање на сите под-категории и нивните URL патеки!
                        </p>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label font-monospace small fw-bold text-muted text-uppercase">Внатрешен опис на структурата</label>
                    <textarea asp-for="Description" class="form-control border shadow-none p-3 font-monospace small" style="border-radius: 8px;" rows="4" placeholder="Технички белешки или опис за администратори..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small fw-bold mt-1 d-block"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center border-top pt-4 mt-5">
                    <a asp-area="Admin" asp-action="Index" class="btn btn-outline-secondary px-4 py-2 fw-medium" style="border-radius: 8px;">
                        <i class="bi bi-x-circle me-2"></i>Отфрли измени
                    </a>
                    <button type="submit" class="btn btn-warning px-5 py-2 fw-bold text-uppercase shadow-sm" style="border-radius: 8px; color: #212529;">
                        <i class="bi bi-save-fill me-2"></i>Пропагирај измени
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}