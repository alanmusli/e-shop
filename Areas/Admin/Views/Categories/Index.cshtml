
@model IEnumerable<e_store.Models.Category>

@{
    ViewData["Title"] = "Категории";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
            <h4 class="fw-bold bistrejd-text-blue mb-1">Системски архитектурен леџер</h4>
            <p class="text-muted small">Управување со хиерархијата на категории</p>
        </div>
        <a asp-area="Admin" asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-circle me-1"></i> Нов јазол
        </a>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 16px;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-uppercase font-monospace small" style="color: #64748b;">
                        <tr>
                            <th class="ps-4" style="width: 40%;">Структура на категории</th>
                            <th style="width: 25%;">URL Slug</th>
                            <th style="width: 15%;">Родител</th>
                            <th class="text-center" style="width: 20%;">Акции</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var rootCategory in Model)
                            {
                                var viewData = new ViewDataDictionary(ViewData) { { "level", 0 } };
                                <partial name="_CategoryRow" model="rootCategory" view-data='viewData' />
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    <i class="bi bi-diagram-3 fs-1 d-block mb-2 opacity-50"></i>
                                    Нема внесено категории во системот.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>