

@model e_store.Models.Category

@{
    int level = ViewData["level"] as int? ?? 0;
}

<tr class="@(level > 0 ? "bg-light bg-opacity-50" : "")">
    <td class="ps-4">
        @if (level > 0)
        {
            <span class="text-muted me-2" style="padding-left: @(level * 20)px;">
                <i class="bi bi-arrow-return-right"></i>
            </span>
        }
        <span class="fw-bold text-dark">@Model.Name</span>
    </td>
    <td>
        <code class="text-primary bg-primary bg-opacity-10 px-2 py-1 rounded small">/@Model.Slug</code>
    </td>
    <td>
        @if (Model.ParentCategory != null)
        {
            <span class="text-muted small font-monospace">@Model.ParentCategory.Name</span>
        }
        else
        {
            <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3">ROOT</span>
        }
    </td>
    <td class="text-center">
        <div class="d-flex justify-content-center gap-1">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-warning border-0">
                <i class="bi bi-pencil-square"></i>
            </a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-danger border-0">
                <i class="bi bi-trash"></i>
            </a>
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-info border-0">
                <i class="bi bi-info-circle"></i>
            </a>
        </div>
    </td>
</tr>

@if (Model.SubCategories != null && Model.SubCategories.Any())
{
    foreach (var subCategory in Model.SubCategories)
    {
        var newViewData = new ViewDataDictionary(ViewData);
        newViewData["level"] = level + 1;
        <partial name="_CategoryRow" model="subCategory" view-data="newViewData" />
    }
}