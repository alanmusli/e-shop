
@model e_store.Models.Category

@{
    ViewData["Title"] = "Нова Категорија";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4" style="max-width: 800px;">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
            <a asp-action="Index" class="btn btn-sm btn-light font-monospace text-uppercase fw-bold text-muted small px-3">
                <i class="bi bi-arrow-left me-2"></i>Откажи
            </a>
        </div>
        <div>
            <span class="badge bg-primary font-monospace px-3 py-2">КРЕИРАЊЕ НА НОВ ЈАЗОЛ</span>
        </div>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 12px;">
        <div class="card-header bg-light border-0 py-3">
            <h5 class="mb-0 fw-bold bistrejd-text-blue">
                <i class="bi bi-folder-plus me-2"></i>Внес на нова категорија
            </h5>
        </div>
        <div class="card-body p-4 p-md-5">
            <form asp-area="Admin" asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 small fw-bold mb-4"></div>

                <div class="mb-4">
                    <label asp-for="Name" class="form-label font-monospace small fw-bold text-muted text-uppercase">Име на категорија</label>
                    <input asp-for="Name" class="form-control border shadow-none py-2" style="border-radius: 8px;" placeholder="Пр: Рачни алати..." />
                    <span asp-validation-for="Name" class="text-danger small fw-bold mt-1 d-block"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ParentCategoryId" class="form-label font-monospace small fw-bold text-muted text-uppercase">Родителска категорија</label>
                    <select asp-for="ParentCategoryId" class="form-select border shadow-none py-2" style="border-radius: 8px;" asp-items="ViewBag.ParentCategoryId">
                        <option value="">-- Избери родител или остави празно за Root --</option>
                    </select>
                    <span asp-validation-for="ParentCategoryId" class="text-danger small fw-bold mt-1 d-block"></span>
                    <div class="mt-2 text-muted font-monospace small">
                        <i class="bi bi-info-circle me-1"></i> Оставајќи го празно, оваа категорија станува независен главен јазол (Root).
                    </div>
                </div>


                <div class="mb-5">
                    <label asp-for="Description" class="form-label font-monospace small fw-bold text-muted text-uppercase">Опис и белешки</label>
                    <textarea asp-for="Description" class="form-control border shadow-none p-3 font-monospace small" style="border-radius: 8px;" rows="3" placeholder="Внесете опис за организација на производите..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small fw-bold mt-1 d-block"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center border-top pt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2 fw-medium" style="border-radius: 8px;">
                        <i class="bi bi-x-circle me-2"></i>Откажи
                    </a>
                    <button type="submit" class="btn btn-primary px-5 py-2 fw-bold text-uppercase shadow-sm" style="border-radius: 8px;">
                        <i class="bi bi-check-circle-fill me-2"></i>Креирај Јазол
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}