@model e_store.Models.Category

<div class="container mt-4" style="max-width: 650px;">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0"><i class="bi bi-folder-plus me-2"></i>Create Structural Category Node</h5>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create" method="post" asp-area="Admin">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger small d-none"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-bold">Category Display Title</label>
                    <input asp-for="Name" class="form-control" placeholder="e.g., Cordless Drills" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ParentCategoryId" class="form-label fw-bold">Parent Node Assignment Placement</label>
                    <select asp-for="ParentCategoryId" class="form-select" asp-items="ViewBag.ParentCategoryId">
                        <option value="-1">-- None (Establish as Top-Level Root Shelf) --</option>
                    </select>
                    <span asp-validation-for="ParentCategoryId" class="text-danger small"></span>
                    <div class="form-text text-muted small">Choosing an option assigns this group as a dependent branch under that parent's relative route.</div>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label fw-bold">Structural Internal Description</label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Define product groupings, indexing criteria, or marketing tagnotes belonging to this group..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center border-top pt-3">
                    <a  asp-area="Admin" asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i> Cancel Setup
                    </a>
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-check-circle me-1"></i> Commit Branch Node
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>