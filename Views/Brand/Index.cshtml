@model IEnumerable<e_store.Models.Brand>

@{
    ViewData["Title"] = "Brand Matrix Portfolio";
    int totalBrands = Model?.Count() ?? 0;
    var currentSlug = ViewContext.RouteData.Values["slug"]?.ToString() ?? "all";
}

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-end mb-5 border-bottom pb-3" style="border-color: rgba(28, 28, 132, 0.1) !important;">
        <div>
            <p class="font-monospace small text-uppercase tracking-wider mb-1" style="color: var(--brand-red); font-weight: 700;">Глобална Мрежа на Партнери</p>
            <h2 class="fw-bold mb-0 bistrejd-text-blue" style="letter-spacing: -0.5px;">Официјални Брендови</h2>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <a asp-controller="Product" asp-action="Index" asp-route-slug="@currentSlug" asp-route-brandName="@item.Name.ToLower()" class="text-decoration-none">
                    <div class="card h-100 border-0 shadow-sm brand-card" style="border-radius: 16px; background-color: #ffffff;">
                        
                        <div class="position-relative p-4 d-flex justify-content-center align-items-center" style="background-color: var(--brand-light); border-radius: 16px 16px 0 0; height: 180px; border-bottom: 1px solid rgba(28, 28, 132, 0.05);">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="@item.Name" class="img-fluid" style="max-height: 100%; object-fit: contain; transition: transform 0.3s ease;" />
                            }
                            else
                            {
                                <div class="text-center">
                                    <i class="bi bi-buildings display-4 mb-2" style="color: var(--brand-blue); opacity: 0.2;"></i>
                                    <h5 class="fw-bold bistrejd-text-blue mb-0">@item.Name</h5>
                                </div>
                            }
                        </div>

                        <div class="card-body text-center p-3">
                            <h5 class="fw-bold bistrejd-text-blue mb-1">@item.Name</h5>
                            <p class="text-muted small mb-0 font-monospace text-uppercase" style="letter-spacing: 0.5px;">
                                Verified Supplier
                            </p>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</div>

<style>
    .brand-card {
        transition: all 0.3s ease;
        border: 1px solid transparent !important;
    }
    
    .brand-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 1rem 3rem rgba(28, 28, 132, 0.1) !important;
        border-color: rgba(28, 28, 132, 0.1) !important;
    }

    .brand-card:hover img {
        transform: scale(1.05);
    }
    
    .brand-card h5 {
        transition: color 0.3s ease;
    }
    
    .brand-card:hover h5 {
        color: var(--brand-red) !important;
    }
</style>