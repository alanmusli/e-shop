@model e_store.Models.Brand

@{
    ViewData["Title"] = $"Profile Ledger - {Model.Name}";
    
    // Fallback or explicit check if you have a Products navigation property on your Brand model
    int associatedProductCount = Model.Products?.Count ?? 0;
}

<div class="container mt-5" style="max-width: 950px;">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Brands Registry</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Name Profile</li>
        </ol>
    </nav>

    <div class="card border-0 shadow-lg overflow-hidden" style="border-radius: 16px;">
        <div class="card-header bg-dark py-3 px-4 d-flex justify-content-between align-items-center">
            <span class="text-white-50 small text-uppercase tracking-wider font-monospace mb-0">Entity Metadata Record</span>
            <span class="badge bg-secondary font-monospace px-2 py-1">SYSTEM REF: #@Model.Id.ToString("D3")</span>
        </div>

        <div class="card-body p-4 p-md-5 bg-white">
            <div class="row g-5">
                
                <div class="col-md-5 border-end">
                    <div class="text-center text-md-start mb-4">
                        <div class="rounded-circle bg-light d-inline-flex align-items-center justify-content-center border mb-3 shadow-sm mx-auto" 
                             style="width: 80px; height: 80px; background: linear-gradient(135deg, #ffffff 0%, #e9ecef 100%);">
                            <i class="bi bi-building-gear text-primary fs-1"></i>
                        </div>
                        <h2 class="fw-black text-dark mb-1">@Model.Name</h2>
                        <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-1 rounded-pill small">
                            <i class="bi bi-shield-check me-1"></i> Active Global Supplier
                        </span>
                    </div>

                    <hr class="my-4 text-muted" />

                    <div class="mb-4">
                        <label class="form-label text-muted small text-uppercase tracking-wide fw-bold">Internal Routing Matrix</label>
                        <div class="bg-light border p-3 rounded font-monospace small position-relative">
                            <i class="bi bi-key-fill text-muted position-absolute end-0 top-50 translate-middle-y me-3"></i>
                            <div class="text-secondary mb-1" style="font-size: 0.7rem;">SYSTEM RESOURCE IDENTIFIER:</div>
                            <code class="text-primary fw-bold">brand-id://@Model.Name.ToLower().Replace(" ", "-")</code>
                        </div>
                    </div>

                    <div class="card bg-gradient border-0 p-3 text-white shadow-sm" style="background: linear-gradient(135deg, #2c3e50 0%, #1a252f 100%); border-radius: 12px;">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <h6 class="text-white-50 small text-uppercase mb-1 fw-bold">Assigned Products</h6>
                                <h3 class="mb-0 font-weight-bold fw-black">@associatedProductCount</h3>
                            </div>
                            <i class="bi bi-boxes text-white-50 fs-2"></i>
                        </div>
                    </div>
                </div>

                <div class="col-md-7 d-flex flex-column justify-content-between">
                    <div>
                        <h5 class="text-dark fw-bold mb-3 pb-2 border-bottom"><i class="bi bi-file-text me-2 text-muted"></i>Profile Documentation</h5>
                        
                        <dl class="row g-3 mb-4">
                            <dt class="col-sm-4 text-secondary small text-uppercase fw-bold">Official Name</dt>
                            <dd class="col-sm-8 text-dark fw-semibold">@Model.Name</dd>

                            <dt class="col-sm-4 text-secondary small text-uppercase fw-bold">Corporate Status</dt>
                            <dd class="col-sm-8 text-dark">
                                <span class="text-success fw-bold"><i class="bi bi-check-circle-fill me-1"></i> Whitelisted Vendor</span>
                            </dd>
                        </dl>

                        @* <div class="mb-4"> *@
                        @*     <h6 class="text-secondary small text-uppercase fw-bold mb-2">Internal Logistics Log / Description</h6> *@
                        @*     <div class="bg-light p-3 rounded border text-secondary lh-base fs-6" style="white-space: pre-line; min-height: 120px;"> *@
                        @*         @(string.IsNullOrWhiteSpace(Model)  *@
                        @*             ? "No specific administrative description or commercial logistics notes have been logged for this supplier entity record."  *@
                        @*             : Model.Description) *@
                        @*     </div> *@
                        @* </div> *@
                    </div>

                    <div class="d-flex flex-wrap gap-2 justify-content-between align-items-center border-top pt-4 mt-auto">
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">
                            <i class="bi bi-arrow-left me-1"></i> Back to Portfolio
                        </a>
                        
                        @if (User.IsInRole("Admin"))
                        {
                            <div class="d-flex gap-2">
                                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger px-4 rounded-pill">
                                    <i class="bi bi-trash3 me-1"></i> Revoke
                                </a>
                                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning text-dark px-4 fw-bold rounded-pill shadow-sm">
                                    <i class="bi bi-pencil-square me-1"></i> Edit Record Ledger
                                </a>
                            </div>
                        }
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>