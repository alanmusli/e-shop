<ul class="navbar-nav align-items-center gap-2">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item">
            <a class="nav-link text-uppercase font-monospace fw-bold" 
               asp-area="Identity" asp-page="/Account/Manage/Index" 
               title="Manage" 
               style="font-size: 13px; color: var(--brand-blue);">
                <i class="bi bi-person-circle me-1"></i> @User.Identity?.Name
            </a>
        </li>
        <li class="nav-item">
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" 
                  asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="nav-link btn btn-link text-uppercase font-monospace fw-bold p-0" 
                        style="font-size: 13px; color: var(--brand-red); text-decoration: none; transition: opacity 0.2s;">
                    Одјава
                </button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-uppercase font-monospace fw-bold" 
               asp-area="Identity" asp-page="/Account/Register" 
               style="font-size: 13px; color: var(--brand-blue);">Регистрација</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-uppercase font-monospace fw-bold px-3 py-1 rounded" 
               asp-area="Identity" asp-page="/Account/Login" 
               style="font-size: 13px; background-color: var(--brand-blue); color: #ffffff; border-radius: 6px !important;">
                Најава
            </a>
        </li>
    }
</ul>