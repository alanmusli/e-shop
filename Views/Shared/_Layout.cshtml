<header>
    <nav class="navbar navbar-expand-lg bg-white shadow-sm border-bottom sticky-top" style="border-color: rgba(28, 28, 132, 0.08) !important; padding-top: 12px; padding-bottom: 12px;">
        <div class="container">
            
            <a class="navbar-brand text-uppercase tracking-wider m-0 pe-4" asp-controller="Home" asp-action="Index" style="color: var(--brand-blue); font-size: 22px; font-weight: 900; letter-spacing: 1.5px;">
                BISTREJD<span style="color: var(--brand-red);">.</span>
            </a>
            
            <button class="navbar-toggler border-0 shadow-none px-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <i class="bi bi-list" style="font-size: 1.8rem; color: var(--brand-blue);"></i>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-1">
                    <li class="nav-item">
                        <a class="nav-link text-uppercase font-monospace fw-bold nav-hover" asp-controller="Product" asp-action="Index" style="font-size: 13px; color: var(--brand-blue);">
                            Продукти
                        </a>
                    </li>
                    
                    @await Component.InvokeAsync("CategoryMenu")
                    
                    <li class="nav-item">
                        <a class="nav-link text-uppercase font-monospace fw-bold nav-hover" asp-controller="Brand" asp-action="Index" style="font-size: 13px; color: var(--brand-blue);">
                            Брендови
                        </a>
                    </li>
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-uppercase font-monospace fw-bold nav-hover" asp-controller="AdminContact" asp-action="Index" style="font-size: 13px; color: var(--brand-blue);">
                                Контакт
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link text-uppercase font-monospace fw-bold nav-hover" asp-controller="Contact" asp-action="Index" style="font-size: 13px; color: var(--brand-blue);">
                                Контакт
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item ms-lg-3 d-flex align-items-center mt-2 mt-lg-0">
                            <a class="nav-link text-uppercase font-monospace fw-bold px-3 py-1 rounded" asp-controller="Categories" asp-action="Index" style="font-size: 11px; background-color: rgba(28, 28, 132, 0.05); color: var(--brand-blue); border: 1px dashed rgba(28, 28, 132, 0.3);">
                                <i class="bi bi-gear-fill me-1"></i> Админ: Категории
                            </a>
                        </li>
                    }
                </ul>
                
                <ul class="navbar-nav align-items-center gap-2 mt-3 mt-lg-0">
                    <li class="nav-item me-lg-2">
                        <a class="nav-link fw-bold d-flex align-items-center" asp-controller="Order" asp-action="Index" style="color: var(--brand-red); transition: transform 0.2s;">
                            <span class="text-uppercase font-monospace" style="font-size: 13px;">Ваши Нарачки</span>
                        </a>
                    </li>
                    <li class="nav-item me-lg-2">
                        <a class="nav-link fw-bold d-flex align-items-center" asp-controller="Cart" asp-action="Index" style="color: var(--brand-red); transition: transform 0.2s;">
                            <i class="bi bi-cart3 fs-5 me-2"></i>
                            <span class="text-uppercase font-monospace" style="font-size: 13px;">Кошничка</span>
                        </a>
                    </li>

                    <li class="nav-item border-start ps-3 ms-1 d-none d-lg-block" style="border-color: rgba(28, 28, 132, 0.1) !important; height: 30px;"></li>

                    <li class="nav-item">
                        <partial name="_LoginPartial"/>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
</header>

<main role="main" class="container py-4">
    @RenderBody()
</main>

@* <footer class="border-top footer text-muted bg-light py-3"> *@
@*     <div class="container text-center"> *@
@*         &copy; 2026 - E-Store Project - <a asp-controller="Home" asp-action="Privacy">Privacy</a> *@
@*     </div> *@
@* </footer> *@

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>

<style>
    .nav-hover {
        transition: all 0.2s ease;
    }
    .nav-hover:hover {
        color: var(--brand-red) !important;
    }
</style>

</html>