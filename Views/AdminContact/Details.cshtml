@model ContactMessage

<div class="container my-5" style="max-width: 800px;">
    <div class="mb-4">
        <a asp-action="Index" class="text-decoration-none text-muted fw-bold">
            <i class="bi bi-arrow-left"></i> Назад кон сите пораки
        </a>
    </div>

    <div class="card border-0 shadow-sm p-4" style="border-radius: 16px;">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-4 border-bottom pb-3">
                <div>
                    <h4 class="fw-bold bistrejd-text-blue mb-1">@Model.Subject</h4>
                    <p class="text-muted small font-monospace mb-0">
                        Примена на: @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                    </p>
                </div>
                <span class="badge" style="background-color: var(--brand-light); color: var(--brand-blue);">
                    ID: #@Model.Id
                </span>
            </div>

            <div class="row mb-4">
                <div class="col-md-6">
                    <label class="text-uppercase font-monospace text-muted" style="font-size: 10px;">Испраќач</label>
                    <div class="fw-bold bistrejd-text-blue">@Model.FullName</div>
                </div>
                <div class="col-md-6">
                    <label class="text-uppercase font-monospace text-muted" style="font-size: 10px;">Е-пошта</label>
                    <div class="fw-bold bistrejd-text-blue">@Model.Email</div>
                </div>
            </div>

            <div class="p-4 bg-light rounded" style="border-radius: 12px !important;">
                <label class="text-uppercase font-monospace text-muted mb-2" style="font-size: 10px;">Содржина на пораката</label>
                <p class="text-dark mb-0" style="line-height: 1.6; font-size: 15px;">
                    @Model.Message
                </p>
            </div>

            <div class="mt-4 d-flex gap-2">
                <a href="mailto:@Model.Email" class="btn bistrejd-btn-red fw-bold text-uppercase px-4" style="border-radius: 8px;">
                    <i class="bi bi-reply-fill me-1"></i> Одговори на Email
                </a>
                <form asp-action="Delete" asp-route-id="@Model.Id" onsubmit="return confirm('Дали сте сигурни?')">
                    <button type="submit" class="btn btn-outline-danger fw-bold text-uppercase px-4" style="border-radius: 8px;">
                        <i class="bi bi-trash"></i> Избриши
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>