@model e_store.Models.Category

<div class="container mt-4" style="max-width: 750px;">
    <div class="card shadow-sm">
        <div class="card-header bg-light d-flex justify-content-between align-items-center py-3">
            <h5 class="mb-0 text-muted"><i class="bi bi-info-circle me-2"></i>Structural Branch Diagnostics</h5>
            <span class="badge bg-secondary">System Entity Hash: #@Model.Id</span>
        </div>
        <div class="card-body p-4">
            <h2 class="mb-1 text-primary"><i class="bi bi-folder-symlink me-2"></i>@Model.Name</h2>
            <p class="text-muted mb-4">
                Absolute Route Slug Compilation: <code class="bg-dark text-light p-1 px-2 rounded fs-6">@Model.Slug</code>
            </p>

            <div class="row bg-light rounded p-3 m-0 mb-4 border">
                <div class="col-sm-4 text-muted fw-bold">Relational Placement Status</div>
                <div class="col-sm-8">
                    @if (Model.ParentCategoryId == null)
                    {
                        <span class="badge bg-primary fs-6">Independent Master Node (Root)</span>
                    }
                    else
                    {
                        <span class="text-dark">
                            Dependent Branch Node of Parent ID: <strong>#@Model.ParentCategoryId</strong>
                        </span>
                    }
                </div>
            </div>

            <div class="mb-3">
                <h6 class="fw-bold text-muted text-uppercase small tracking-wide">Category Ledger Description</h6>
                <p class="lh-base bg-white p-3 border rounded text-secondary" style="white-space: pre-line;">
                    @(string.IsNullOrWhiteSpace(Model.Description) ? "No structural notes logged for this category ledger line item entry." : Model.Description)
                </p>
            </div>
        </div>
        <div class="card-footer bg-light d-flex justify-content-between py-3">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Back to Tree Grid
            </a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning text-dark px-4">
                <i class="bi bi-pencil me-1"></i> Re-align Hierarchy
            </a>
        </div>
    </div>
</div>