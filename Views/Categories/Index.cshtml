@model IEnumerable<e_store.Models.Category>

@{
    ViewData["Title"] = "Categories Master Panel";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-diagram-3 me-2"></i>Store Architecture Ledger</h5>
            <a asp-action="Create" class="btn btn-sm btn-success">
                <i class="bi bi-plus-circle me-1"></i> Create New Node
            </a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light border-bottom text-muted small text-uppercase">
                        <tr>
                            <th style="width: 45%;" class="ps-4">Category System Structure</th>
                            <th style="width: 25%;">Absolute URL Routing Slug</th>
                            <th style="width: 15%;">Parent Allocation</th>
                            <th style="width: 15%;" class="text-center">Management Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var rootCategory in Model)
                            {
                                var viewData = new ViewDataDictionary(ViewData) { { "level", 0 } };
                                <partial name="_CategoryRow" model="rootCategory" view-data='viewData' />
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-5">
                                    <i class="bi bi-folder-x display-6 d-block mb-2 text-secondary"></i>
                                    No database entries logged. Run your data initialization seed rules.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>