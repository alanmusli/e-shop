@model CategoryBrandViewModel
@{
    ViewData["Title"] = "Почетна";
}


<div class="position-relative overflow-hidden text-center shadow-lg mb-5" style="background: linear-gradient(135deg, var(--brand-blue) 0%, #0a0a32 100%); border-radius: 0 0 40px 40px;">
    <div class="col-md-10 col-lg-8 p-lg-5 mx-auto my-5 py-5 position-relative" style="z-index: 1;">
        
        <p class="font-monospace fw-bold mb-3 tracking-wider text-uppercase" style="color: var(--brand-red); letter-spacing: 2px;">
            <i class="bi bi-star-fill me-2"></i>Премиум квалитет
        </p>
        
        <h1 class="display-3 fw-bold mb-4 text-white" style="letter-spacing: -1px;">
            Професионални алати за секој мајстор
        </h1>
        
        <p class="lead fw-normal text-white-50 mb-5 mx-auto" style="max-width: 600px;">
            Откријте го нашиот премиум каталог на алати и опрема. Врвен квалитет, докажани брендови и сигурна достава директно до вашата врата.
        </p>
        
        <div class="row justify-content-center mb-5">
            <div class="col-md-10 col-lg-9">
                <form asp-controller="Product" asp-action="Index" method="get">
                    <div class="input-group input-group-lg shadow-lg" style="border-radius: 16px; overflow: hidden; border: 3px solid rgba(255,255,255,0.1);">
                        <span class="input-group-text bg-white border-0 text-muted ps-4">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" name="searchQuery" class="form-control border-0 px-3 shadow-none" placeholder="Пребарајте " required style="font-size: 16px;">
                        <button class="btn bistrejd-btn-red fw-bold px-4 px-md-5 text-uppercase" type="submit" style="font-size: 15px; letter-spacing: 1px;">
                            Барај
                        </button>
                    </div>
                </form>
            </div>
        </div>
        
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a asp-controller="Product" asp-action="Index" class="btn btn-light btn-lg px-5 py-3 fw-bold text-uppercase d-flex align-items-center shadow-sm" style="color: var(--brand-blue);">
                <i class="bi bi-grid-fill me-2"></i> Цел Каталог
            </a>
            <a asp-controller="Contact" asp-action="Index" class="btn btn-outline-light btn-lg px-5 py-3 fw-bold text-uppercase d-flex align-items-center">
                Контакт
            </a>
        </div>
    </div>
    
    <i class="bi bi-tools position-absolute" style="font-size: 25rem; color: rgba(255,255,255,0.02); bottom: -50px; right: -50px; transform: rotate(-15deg); z-index: 0;"></i>
</div>

<div class="container mb-5">
    <div class="row g-4 mb-5 pb-5 border-bottom" style="border-color: rgba(28, 28, 132, 0.1) !important;">
        <!-- Достава -->
        <div class="col-md-4 text-center">
            <div class="d-inline-flex align-items-center justify-content-center bg-light rounded-circle mb-3 shadow-sm" style="width: 80px; height: 80px;">
                <i class="bi bi-truck display-5 bistrejd-text-blue"></i>
            </div>
            <h5 class="fw-bold bistrejd-text-blue">Брза Достава</h5>
            <p class="text-muted small">Испорака низ цела држава во рок од 24-48 часа за сите нарачки.</p>
        </div>
        
        <!-- Сигурно Плаќање -->
        <div class="col-md-4 text-center">
            <div class="d-inline-flex align-items-center justify-content-center bg-light rounded-circle mb-3 shadow-sm" style="width: 80px; height: 80px;">
                <i class="bi bi-shield-check display-5 bistrejd-text-blue"></i>
            </div>
            <h5 class="fw-bold bistrejd-text-blue">Сигурно Плаќање</h5>
            <p class="text-muted small mb-1">100% безбедни трансакции и заштита на вашите податоци.</p>
            <span class="badge bg-warning text-dark font-monospace" style="font-size: 10px;">soon implementing..</span>
        </div>
        
        <!-- Оригинални Брендови -->
        <div class="col-md-4 text-center">
            <div class="d-inline-flex align-items-center justify-content-center bg-light rounded-circle mb-3 shadow-sm" style="width: 80px; height: 80px;">
                <i class="bi bi-patch-check display-5 bistrejd-text-blue"></i>
            </div>
            <h5 class="fw-bold bistrejd-text-blue">Оригинални Брендови</h5>
            <p class="text-muted small">Овластени дистрибутери за сите брендови во нашиот каталог.</p>
        </div>
    </div>

    <div class="text-center mb-5">
        <p class="font-monospace small text-uppercase tracking-wider mb-1" style="color: var(--brand-red); font-weight: 700;">Глобална Мрежа</p>
        <h2 class="fw-bold bistrejd-text-blue mb-4">Наши Доверливи Партнери</h2>
    </div>

    <div class="row row-cols-2 row-cols-md-4 g-4 text-center justify-content-center">
        @foreach (var item in Model.Brands)
        {
            <div class="col">
                <div class="card border-0 shadow-sm h-100 py-3 brand-hover-card" style="border-radius: 12px; background-color: var(--brand-light);">
                    <div class="card-body d-flex flex-column justify-content-center align-items-center">
                        <img src="@item.ImageUrl" 
                             alt="@item.Name" 
                             class="img-fluid brand-logo" 
                             style="max-height: 40px;" />
                        
                        <h6 class="fw-bold bistrejd-text-blue mb-0">@item.Name</h6>
                    </div>
                </div>
            </div>
        }
    </div>
    
    <div class="text-center mt-5">
        <a asp-controller="Brand" asp-action="Index" class="btn btn-outline-secondary font-monospace text-uppercase fw-bold px-4 rounded-pill" style="font-size: 12px;">
            Сите брендови <i class="bi bi-arrow-right ms-1"></i>
        </a>
    </div>
</div>
<style>
    .brand-logo {
        filter: grayscale(100%);     
        transition: all 0.4s ease;   
        opacity: 0.6;                
    }

    .brand-hover-card:hover .brand-logo {
        filter: grayscale(0%);       
        opacity: 1;                  
    }

    .brand-hover-card {
        transition: all 0.3s ease;
        cursor: pointer;
    }
    
    .brand-hover-card:hover {
        transform: translateY(-5px);
        background-color: #ffffff !important;
        box-shadow: 0 10px 20px rgba(28, 28, 132, 0.1) !important;
    }
</style>