@model e_store.Models.Cart

@{
    ViewData["Title"] = "Моја Кошничка - Bistrejd";
    int totalItems = Model?.CartItems?.Sum(ci => ci.Quantity) ?? 0;
    decimal runningSubtotal = Model?.CartItems?.Sum(ci => ci.Quantity * (ci.Product?.Price ?? 0)) ?? 0;
}

<div class="container fade-in" style="margin-top: 3rem; margin-bottom: 5rem;">
    <div class="d-flex justify-content-between align-items-end mb-4 pb-3 border-bottom" style="border-color: rgba(28, 28, 132, 0.1) !important;">
        <div>
            <h1 class="display-6 fw-bold bistrejd-text-blue mb-1" style="letter-spacing: -1px;">Моја Кошничка</h1>
            <p class="text-muted mb-0">Прегледајте ги вашите продукти, променете ја количината и продолжете кон наплата.</p>
        </div>
        @if (totalItems > 0)
        {
            <form asp-action="ClearCart" method="post" asp-route-id="@Model.Id">
                <button type="submit" class="btn btn-light text-danger btn-sm rounded-pill px-4 fw-bold border shadow-sm transition-all" style="font-size: 13px;">
                    <i class="bi bi-trash3 me-1"></i> Испразни ја кошничката
                </button>
            </form>
        }
    </div>

    @if (Model == null || Model.CartItems == null || !Model.CartItems.Any())
    {
        <div class="card border-0 shadow-sm rounded-4 py-5 my-5 text-center" style="background-color: var(--brand-light);">
            <div class="card-body py-5">
                <div class="rounded-circle bg-white d-inline-flex align-items-center justify-content-center mb-4 shadow-sm" style="width: 100px; height: 100px; color: var(--brand-blue);">
                    <i class="bi bi-cart-x display-4"></i>
                </div>
                <h3 class="fw-bold bistrejd-text-blue mb-3">Вашата кошничка е празна</h3>
                <p class="text-muted mx-auto mb-4" style="max-width: 400px;">Сеуште немате додадено продукти. Разгледајте го нашиот каталог и пронајдете го она што ви е потребно.</p>
                <a asp-controller="Product" asp-action="Index" class="btn bistrejd-btn-red px-5 py-3 fw-bold rounded-pill shadow-sm text-uppercase" style="letter-spacing: 1px;">
                    <i class="bi bi-bag-plus me-2 fs-5"></i> Разгледај Продукти
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0 bg-white table-hover">
                            <thead class="text-muted small text-uppercase font-monospace" style="background-color: #f8fafc; letter-spacing: 0.5px;">
                                <tr>
                                    <th scope="col" class="ps-4 py-3 border-0" style="width: 50%;">Продукт</th>
                                    <th scope="col" class="py-3 text-center border-0" style="width: 20%;">Количина</th>
                                    <th scope="col" class="py-3 text-end border-0" style="width: 20%;">Вкупно</th>
                                    <th scope="col" class="py-3 text-center border-0" style="width: 10%;">Избриши</th>
                                </tr>
                            </thead>
                            <tbody style="border-top: 2px solid rgba(28, 28, 132, 0.05);">
                                @foreach (var item in Model.CartItems)
                                {
                                    var itemTotal = item.Quantity * (item.Product?.Price ?? 0);
                                    <tr class="cart-row">
                                        <td class="ps-4 py-3">
                                            <div class="d-flex align-items-center">
                                                <div class="rounded-3 bg-white border p-1 me-3 d-flex align-items-center justify-content-center shadow-sm" style="width: 60px; height: 60px; min-width: 60px; overflow: hidden;">
                                                    <i class="bi bi-image text-muted fs-4"></i>
                                                </div>
                                                <div>
                                                    <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId" class="text-decoration-none text-dark">
                                                        <h6 class="mb-1 fw-bold text-truncate bistrejd-text-blue hover-primary" style="max-width: 260px; transition: color 0.2s;">@item.Product?.Name</h6>
                                                    </a>
                                                    <span class="text-muted small d-block font-monospace">Цена: @item.Product?.Price.ToString("N0") ден.</span>
                                                </div>
                                            </div>
                                        </td>
                                        
                                        <td class="text-center">
                                            <form asp-action="UpdateQuantity" method="post" class="d-inline-flex align-items-center border rounded-pill bg-white p-1 shadow-sm" asp-route-id="@Model.Id">
                                                <input type="hidden" name="itemId" value="@item.Id" />
                                                <button type="submit" name="direction" value="down" class="btn btn-sm btn-light rounded-circle p-0 d-flex align-items-center justify-content-center text-secondary qty-btn" style="width: 28px; height: 28px;">
                                                    <i class="bi bi-dash"></i>
                                                </button>
                                                <span class="px-3 fw-bold text-dark font-monospace fs-6">@item.Quantity</span>
                                                <button type="submit" name="direction" value="up" class="btn btn-sm btn-light rounded-circle p-0 d-flex align-items-center justify-content-center text-secondary qty-btn" style="width: 28px; height: 28px;">
                                                    <i class="bi bi-plus"></i>
                                                </button>
                                            </form>
                                        </td>
                                        
                                        <td class="text-end fw-bold text-dark font-monospace pe-3 fs-6">
                                            @itemTotal.ToString("N0") ден.
                                        </td>
                                        
                                        <td class="text-center pe-4">
                                            <form asp-action="RemoveItem" method="post">
                                                <input type="hidden" name="itemId" value="@item.Id" />
                                                <button type="submit" class="btn btn-link text-danger p-0 delete-btn" title="Избриши продукт">
                                                    <i class="bi bi-x-circle-fill fs-5 opacity-75 transition-all"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                
                <div class="mt-2">
                    <a asp-controller="Product" asp-action="Index" class="btn btn-link text-decoration-none p-0 fw-bold bistrejd-text-blue hover-opacity">
                        <i class="bi bi-arrow-left me-2"></i> Продолжи со купување
                    </a>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 position-sticky" style="top: 24px; background-color: #fff;">
                    <div class="card-body p-4 p-md-5">
                        <h5 class="fw-bold mb-4 bistrejd-text-blue border-bottom pb-3">Преглед на нарачка</h5>
                        
                        <div class="d-flex justify-content-between mb-3 text-muted small">
                            <span>Вкупно продукти:</span>
                            <span class="fw-bold font-monospace text-dark">@totalItems пар.</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3 text-muted small">
                            <span>Испорака:</span>
                            <span class="fw-bold font-monospace text-dark">Ќе се пресмета</span>
                        </div>
                        
                        <div class="p-3 rounded-3 mt-4 mb-4" style="background-color: var(--brand-light);">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold bistrejd-text-blue text-uppercase small" style="letter-spacing: 0.5px;">За Наплата:</span>
                                <span class="fs-4 fw-bold font-monospace" style="color: var(--brand-red);">@runningSubtotal.ToString("N0") ден.</span>
                            </div>
                        </div>

                        <a asp-controller="Order" asp-action="Checkout" class="btn bistrejd-btn-red btn-lg w-100 fw-bold shadow-sm py-3 rounded-3 d-flex align-items-center justify-content-center text-uppercase transition-all" style="letter-spacing: 1px; font-size: 14px;">
                            Продолжи кон наплата <i class="bi bi-chevron-right ms-2"></i>
                        </a>
                        
                        <div class="text-center mt-4">
                            <span class="text-muted small font-monospace d-flex align-items-center justify-content-center">
                                <i class="bi bi-shield-lock-fill me-2 fs-6 text-success"></i> Сигурно и енкриптирано плаќање
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .fade-in {
        animation: fadeIn 0.4s ease-in;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .cart-row {
        transition: background-color 0.2s ease;
    }

    .cart-row:hover {
        background-color: #f8fafc;
    }

    .hover-primary:hover {
        color: var(--brand-red) !important;
    }
    
    .hover-opacity:hover {
        opacity: 0.7;
    }

    .qty-btn:hover {
        background-color: #e2e8f0 !important;
    }

    .delete-btn:hover i {
        opacity: 1;
        transform: scale(1.1);
    }
    
    .table > :not(caption) > * > * {
        border-bottom-color: rgba(28, 28, 132, 0.05);
    }
</style>