@model Cart

@{
    ViewBag.Title = "title";
    Layout = "_Layout";
}

<h2>Your Cart</h2>


<table>
    <thead>
    <tr>
        <th>Name</th>
        <th>Description</th>
        <th>Price</th>
        <th>Created Date</th>
    </tr>
    </thead>

    <tbody>
    @foreach (var item in @Model.CartItems)
    {
        <tr>
            <td>@item.Product.Name</td>
            <td>@item.Product.Description</td>
            <td>@item.Product.Price</td>
            <td>@item.Product.CreatedDate</td>
        </tr>
    }
    </tbody>


</table>