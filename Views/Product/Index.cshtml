<div class="container my-5">
    <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-3" style="border-color: rgba(28, 28, 132, 0.2) !important;">
        <div>
            <p class="font-monospace small text-uppercase tracking-wider mb-1" style="color: var(--brand-red); font-weight: 700;">Официјален Каталог</p>
            <h2 class="fw-bold mb-0" style="color: var(--brand-blue); letter-spacing: -0.5px;">@ViewBag.CurrentCategoryName</h2>
        </div>
        
        <div class="d-none d-md-block">
            <form asp-controller="Product" asp-action="Index" 
                  asp-route-slug="@currentSlug" 
                  asp-route-brandName="@currentBrand" 
                  method="get">
        
                @if (!string.IsNullOrEmpty(ViewBag.SearchQuery as string))
                {
                    <input type="hidden" name="searchQuery" value="@ViewBag.SearchQuery" />
                }

                <select name="sortOrder" onchange="this.form.submit();" class="form-select border-1 shadow-sm font-monospace small" style="border-color: rgba(28, 28, 132, 0.2); color: var(--brand-blue);">
            
                    @if (string.IsNullOrEmpty(ViewBag.CurrentSort) || ViewBag.CurrentSort == "newest")
                    {
                        <option value="newest" selected>Сортирај по најнови</option>
                    }
                    else
                    {
                        <option value="newest">Сортирај по најнови</option>
                    }

                    @if (ViewBag.CurrentSort == "price_asc")
                    {
                        <option value="price_asc" selected>Цена: Растечка</option>
                    }
                    else
                    {
                        <option value="price_asc">Цена: Растечка</option>
                    }

                    @if (ViewBag.CurrentSort == "price_desc")
                    {
                        <option value="price_desc" selected>Цена: Опаѓачка</option>
                    }
                    else
                    {
                        <option value="price_desc">Цена: Опаѓачка</option>
                    }
            
                </select>
            </form>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 border-0 shadow-sm product-card" style="border-radius: 12px; background-color: #ffffff;">
                    
                    <div class="position-relative p-4 d-flex justify-content-center align-items-center" style="background-color: var(--brand-light); border-radius: 12px 12px 0 0; height: 220px;">
                        <img src="@item.ImageUrl" class="img-fluid object-fit-contain product-image" alt="@item.Name" style="max-height: 160px;">
                        
                        @if(item.InventoryCount > 0) 
                        {
                            <span class="badge position-absolute top-0 end-0 m-3 shadow-sm font-monospace" style="background-color: var(--brand-blue); font-size: 10px;">На залиха</span>
                        } 
                        else 
                        {
                            <span class="badge bg-secondary position-absolute top-0 end-0 m-3 shadow-sm font-monospace" style="font-size: 10px;">Распродадено</span>
                        }
                    </div>

                    <div class="card-body d-flex flex-column p-4">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-uppercase font-monospace fw-bold" style="font-size: 11px; color: #6c757d;">@item.Brand.Name</span>
                        </div>

                        <h6 class="card-title fw-bold mb-3" style="color: var(--brand-blue); line-height: 1.4;">
                            @item.Name
                        </h6>

                        <div class="mt-auto">
                            <p class="fs-5 fw-bold mb-0" style="color: var(--brand-red);">@item.Price.ToString("F2") den</p>
                        </div>
                    </div>

                    <div class="card-footer bg-transparent border-0 p-4 pt-0">
                        <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" 
                           class="btn w-100 fw-bold text-uppercase tracking-wider shadow-sm d-flex justify-content-center align-items-center action-btn" 
                           style="background-color: var(--brand-red); color: white; border-radius: 6px; font-size: 12px;">
                            <i class="bi bi-cart-plus me-2 fs-5"></i>
                            <span>Погледни детали</span>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    
    .product-card {
        transition: all 0.3s ease;
        border: 1px solid rgba(28, 28, 132, 0.05) !important;
    }
    
    .product-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 1rem 3rem rgba(28, 28, 132, 0.15) !important;
        border-color: rgba(28, 28, 132, 0.15) !important;
    }
    
    .product-image {
        transition: transform 0.3s ease;
    }
    
    .product-card:hover .product-image {
        transform: scale(1.08);
    }

    .action-btn {
        transition: all 0.3s ease;
    }
    
    .action-btn:hover {
        background-color: var(--brand-blue) !important;
        color: white !important;
    }
</style>
